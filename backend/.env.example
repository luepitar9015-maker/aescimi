# ============================================================
# VARIABLES DE ENTORNO DEL BACKEND - SENA SGDEA
# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# --- Seguridad JWT ---
# Genera un valor aleatorio seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_UN_VALOR_SECRETO_LARGO_Y_ALEATORIO

# --- Base de Datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sena_db
DB_USER=postgres
DB_PASSWORD=REEMPLAZA_CON_TU_CONTRASENA_DE_BD

# --- Orígenes Permitidos (CORS) ---
# Dominio del frontend en producción (Vercel u otro)
FRONTEND_URL=https://

# --- Entorno ---
NODE_ENV=development
